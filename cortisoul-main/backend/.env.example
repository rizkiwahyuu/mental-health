NODE_ENV=development
HOST=0.0.0.0
PORT=5000

DATABASE_URL=postgresql://cortisoul:cortisoul@localhost:5433/cortisoul

# Set CACHE_ENABLED=false jika Redis belum aktif saat development lokal.
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=false

ACCESS_TOKEN_KEY=replace-with-a-long-random-secret
REFRESH_TOKEN_KEY=replace-with-another-long-random-secret

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@cortisoul.local

PREDICT_SERVICE_URL=http://localhost:8000
PREDICT_FALLBACK_ENABLED=true

REFLECTION_SERVICE_URL=http://localhost:8001
REFLECTION_FALLBACK_ENABLED=true
CORS_ORIGIN=http://localhost:3000
